{
  "layer": "top",
  "position": "top",
  "height": 30,
  "spacing": 0,
  "fixed-center": false,
  "exclusive": true,
  "modules-left": [
    "hyprland/workspaces",
    "custom/user"
  ],
  "modules-center": [
    "custom/icon",
    "hyprland/window"
  ],
  "modules-right": [
    "idle_inhibitor",
    "tray",
    "custom/music",
    "privacy",
    // "custom/minecraft",
    "custom/pacman_updates",
    "custom/ollama",
    //   "keyboard-state",
    "network",
    "custom/autotun",
    "bluetooth",
    "group/hardware",
    "backlight",
    "pulseaudio",
    "battery",
    "clock#date",
    "clock"
  ],
  "group/hardware": {
    "orientation": "horizontal",
    "modules": [
      "custom/temperature",
      "cpu",
      "memory",
      "custom/cpufreq"
    ]
  },
  "hyprland/workspaces": {
    "format": "{id}",
    "on-scroll-up": "hyprctl dispatch 'hl.dsp.focus({ workspace = \"e-1\" })'",
    "on-scroll-down": "hyprctl dispatch 'hl.dsp.focus({ workspace = \"e+1\" })'"
  },
  "hyprland/window": {
    "format": "{class}",
    "icons": true
  },
  "tray": {
    "spacing": "2",
    "show-passive-items": "true"
  },
  "idle_inhibitor": {
    "format": "{icon} ",
    "format-icons": {
      "activated": "яБо",
      "deactivated": "яБ░"
    }
  },
  "custom/user": {
    "exec": "whoami | sed -E 's/(.)(.*)/\\U\\1\\L\\2/'",
    "format": "{}"
  },
  "custom/icon": {
    "format": "яМГ яНЩ ",
    "on-click": "kill \"$(pgrep --euid \"$(whoami)\" waybar)\"; uwsm app -s s -t service -- waybar"
  },
  "custom/music": {
    "exec": "$HOME/.config/waybar/scripts/music.sh",
    "return-type": "json",
    "format": "{}",
    "interval": 10,
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "on-scroll-up": "playerctl volume 0.1+",
    "on-scroll-down": "playerctl volume 0.1-"
  },
  "custom/pacman_updates": {
    "exec": "bash $HOME/.config/waybar/scripts/pacman-updates.sh",
    "hide-empty-text": false,
    "return-type": "json",
    "format": "{}",
    "interval": 600,
    "on-click": "hyprctl dispatch 'hl.dsp.exec_cmd(\"uwsm app -a topgrade -- alacritty -e topgrade -t\", { workspace = \"special:s1\" })'"
  },
  "custom/ollama": {
    "exec": "$HOME/.config/waybar/scripts/ollama-running.sh",
    "hide-empty-text": true,
    "return-type": "json",
    "format": "{}",
    "interval": 10,
    "on-click": "$HOME/.config/waybar/scripts/ollama-running.sh --kill"
  },
  "custom/minecraft": {
    "exec": "bash $HOME/.config/waybar/scripts/minecraft.sh",
    "hide-empty-text": false,
    "return-type": "json",
    "format": "{}",
    "interval": 60,
    "on-click": "hyprctl dispatch 'hl.dsp.exec_cmd(\"uwsm app -- lutris lutris:rungame/minecraft-java-edition\")'"
  },
  "custom/autotun": {
    "exec": "bash $HOME/.config/waybar/scripts/autotun.sh",
    "hide-empty-text": false,
    "return-type": "json",
    "format": "{}",
    "interval": 10,
    "on-click": "bash $HOME/.config/waybar/scripts/autotun.sh --toggle"
  },
  "clock": {
    "format": "{:%H:%M}",
    "format-alt": "{:%H:%M:%S}",
    "tooltip-format": "{:%A (%U) | %d %B %Y (%j) | %H:%M:%S%z (%Z)}",
    "interval": 1
  },
  "clock#date": {
    "format": "{:%a %d-%m}",
    "format-alt": "{:%A %d %B %Y}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "ґ░ГЮ",
      "ґ░ГЯ",
      "ґ░Га"
    ],
    "reverse-scrolling": true,
    "on-scroll-up": "brightnessctl --device='amdgpu_bl1' set +1%",
    "on-scroll-down": "brightnessctl --device='amdgpu_bl1' set 1%-",
    "on-click": "brightnessctl --device='amdgpu_bl1' set 1%-",
    "on-click-right": "brightnessctl --device='amdgpu_bl1' set +1%"
  },
  "battery": {
    "interval": 15,
    "format-icons": [
      "яЙД",
      "яЙГ",
      "яЙВ",
      "яЙБ",
      "яЙА"
    ],
    "format": "{icon}  {capacity}%",
    "format-charging": "яЗж {capacity}%",
    "format-plugged": "яЗж {capacity}%",
    "format-alt": "{icon}  {time}",
    "states": {
      "warning": 25,
      "critical": 15
    }
  },
  "memory": {
    "format": "ю┐Е  {used:0.1f}G",
    "states": {
      "high": 70,
      "critical": 90
    },
    "on-click": "hyprctl dispatch 'hl.dsp.exec_cmd(\"uwsm app -a free -- alacritty -e watch -n 1 free -h\")'",
    "tooltip-format": "{used} GB/{total} GB used ({percentage}%)\n{swapUsed} GB/{swapTotal} GB swap used ({swapPercentage}%)"
  },
  "temperature": {
    "thermal-zone": 8,
    "format": "яЛЙ {temperatureC}┬░C",
    "format-critical": "яЛЗ {temperatureC}┬░C",
    "critical-threshold": 70,
    "on-click": "hyprctl dispatch 'hl.dsp.exec_cmd(\"uwsm app -a sensors -- alacritty -e watch -n 1 sensors\")'"
  },
  "custom/temperature": {
    "exec": "bash $HOME/.config/waybar/scripts/temperature.sh",
    "return-type": "json",
    "format": "яЛЙ {}┬░C",
    "interval": 10,
    "on-click": "hyprctl dispatch 'hl.dsp.exec_cmd(\"uwsm app -a sensors -- alacritty -e watch -n 1 sensors\")'"
  },
  "custom/cpufreq": {
    "exec": "bash $HOME/.config/waybar/scripts/cpufreq.sh",
    "return-type": "json",
    "format": "ґ░УЕ {}",
    "on-click": "$HOME/.config/waybar/scripts/tlp-switch.sh left",
    "on-click-right": "$HOME/.config/waybar/scripts/tlp-switch.sh right",
    "interval": 5
  },
  "cpu": {
    "format": "яТ╝ {usage}%",
    "states": {
      "high": 70,
      "critical": 90
    },
    "on-click": "hyprctl dispatch 'hl.dsp.exec_cmd(\"uwsm app -a htop -- alacritty -e htop\")'"
  },
  "network": {
    "format-ethernet": "ю╝Й  {ifname}",
    "format-wifi": "{icon}  {essid}",
    "format-linked": "яВм   {ifname}",
    "format-disconnected": "ґ░МЩ  ",
    "format-icons": [
      "ґ░дЯ",
      "ґ░дв",
      "ґ░де",
      "ґ░ди"
    ],
    "tooltip-format-wifi": "{ipaddr}\nSignal Strength: {signalStrength}%",
    "tooltip-format-ethernet": "{ipaddr}",
    "tooltip-format-disconnected": "Disconnected",
    "on-click": "nmcli device wifi rescan; hyprctl dispatch 'hl.dsp.exec_cmd(\"uwsm app -a nmtui-connect -- alacritty -e nmtui-connect\", { float = true, center = true, no_blur = true })'",
    "on-click-middle": "hyprctl dispatch 'hl.dsp.exec_cmd(\"uwsm app -- nm-connection-editor\")'",
    "on-click-right": "rfkill toggle wlan"
  },
  "bluetooth": {
    "format-off": "ґ░В▓",
    "format-on": "ґ░Вп",
    "format-disabled": "ґ░В▓",
    "format-connected": "ґ░В▒ {device_alias}",
    "tooltip-format-disabled": "Bluetooth disabled",
    "tooltip-format-off": "Bluetooth off",
    "tooltip-format-on": "Bluetooth device not connected",
    "tooltip-format-connected": "Connected to device: {device_alias} ({device_battery_percentage})",
    "on-click": "hyprctl dispatch 'hl.dsp.exec_cmd(\"uwsm app -a bluetoothctl -- alacritty -e bluetoothctl\", { float = true, center = true, no_blur = true })'",
    "on-click-middle": "bluetoothctl disconnect || IFS=$'\n'; for device in $(bluetoothctl devices Trusted); do (echo $device | awk '{print $2}' | xargs bluetoothctl connect &); done",
    "on-click-right": "rfkill toggle bluetooth"
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "ґ░ЭЯ {volume}%",
    "format-icons": {
      "default": [
        "яАж",
        "яАз",
        "яАи "
      ],
      "speaker": [
        "яАж",
        "яАз",
        "яАи "
      ],
      "headphone": [
        "ґ░ЛЛ яАж",
        "ґ░ЛЛ яАз",
        "ґ░ЛЛ яАи "
      ],
      "headset": [
        "яКФ яАж",
        "яКФ яАз",
        "яКФ яАи "
      ],
      "hands-free": [
        "яКФ яАж",
        "яКФ яАз",
        "яКФ яАи "
      ]
    },
    "on-click": "hyprctl dispatch 'hl.dsp.exec_cmd(\"uwsm app -- pwvucontrol\", { float = true, center = true, no_blur = true })'",
    "on-click-right": "wpctl set-mute @DEFAULT_SINK@ toggle",
    "reverse-scrolling": true
  },
  "keyboard-state": {
    "format": {
      "capslock": "HI{icon}",
      "numlock": "HIE"
    },
    "format-icons": {
      "locked": "яАг Caps Locked",
      "unlocked": ""
    },
    "numlock": false,
    "capslock": true,
    "scrolllock": false
  },
  "privacy": {
    "icon-spacing": 4,
    "icon-size": 18,
    "transition-duration": 250,
    "on-click": "playerctl pause",
    "modules": [
      {
        "type": "screenshare",
        "tooltip-icon-size": 24
      },
      {
        "type": "audio-in",
        "tooltip-icon-size": 24
      },
      {
        "type": "audio-out",
        "tooltip-icon-size": 24
      }
    ]
  }
}
