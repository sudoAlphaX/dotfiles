# Allow java
include allow-java.inc
whitelist /usr/share/java
noblacklist ${HOME}/.openjfx
mkdir ${HOME}/.openjfx
whitelist ${HOME}/.openjfx

# Allow lua (gamescope)
include allow-lua.inc

# If you use gamescope, add the following to lutris.local to work around a bug
# (see #6191):
ignore noroot
ignore private-tmp

# Shared dir
ignore noroot
ignore nogroups

noblacklist ${HOME}/Shared/Games
whitelist ${HOME}/Shared/Games

mkdir ${HOME}/Shared/Downloads
noblacklist ${HOME}/Shared/Downloads
whitelist ${HOME}/Shared/Downloads

noblacklist ${HOME}/.cache/umu
mkdir ${HOME}/.cache/umu
whitelist ${HOME}/.cache/umu

noblacklist ${HOME}/.local/share/umu
mkdir ${HOME}/.local/share/umu
whitelist ${HOME}/.local/share/umu

noblacklist ${HOME}/.local/share/Steam
mkdir ${HOME}/.local/share/Steam
whitelist ${HOME}/.local/share/Steam

# Tray icon
dbus-user.own org.kde.*
dbus-user.talk org.kde.StatusNotifierWatcher

# Discord
whitelist ${RUNUSER}/discord-ipc-*

# tmp extraction for simple-voice-chat mod minecraft
ignore noexec /tmp

ignore restrict-namespaces
ignore seccomp
