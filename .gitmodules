[submodule ".config/tmux/tpm"]
	path = .config/tmux/tpm
	url = https://github.com/tmux-plugins/tpm
[submodule "omz"]
	path = .oh-my-zsh
	url = https://github.com/ohmyzsh/ohmyzsh
[submodule "assets/omz-custom/plugins/zsh-autocomplete"]
	path = assets/omz-custom/plugins/zsh-autocomplete
	url = https://github.com/marlonrichert/zsh-autocomplete
[submodule "assets/omz-custom/plugins/zsh-syntax-highlighting"]
	path = assets/omz-custom/plugins/zsh-syntax-highlighting
	url = https://github.com/zsh-users/zsh-syntax-highlighting
[submodule "assets/omz-custom/themes/powerlevel10k"]
	path = assets/omz-custom/themes/powerlevel10k
	url = https://github.com/romkatv/powerlevel10k
